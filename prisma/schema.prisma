// ============================================================
// schema.prisma — P.A.S.T WORKSPACE (Lark Clone)
// Stack: Next.js App Router + Prisma ORM + Supabase
// Security: RLS enforced at DB layer (xem file rls.sql)
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"] // hỗ trợ Supabase multi-schema
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────────────────────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────────────────────

enum MemberRole {
  admin
  leader
  member
}

enum ChannelType {
  PUBLIC
  PRIVATE
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum AttendanceStatus {
  pending
  yes
  no
}

enum ProposalStatus {
  pending
  approved
  rejected
}

// ────────────────────────────────────────────────────────────
// MODEL 1: Profile
// Liên kết 1-1 với Supabase auth.users qua UUID
// Security: id = auth.uid() từ Supabase Auth
// ────────────────────────────────────────────────────────────

model Profile {
  id        String     @id @db.Uuid // Phải khớp với auth.uid() của Supabase
  fullName  String     @map("full_name")
  avatarUrl String?    @map("avatar_url")
  role      MemberRole @default(member)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Relations
  ownedChannels      Channel[]           @relation("ChannelOwner")
  channelMemberships ChannelMember[]
  sentMessages       Message[]           @relation("MessageSender")
  messageReadStatus  MessageReadStatus[]
  pinnedItems        PinnedItem[]        @relation("PinnedBy")

  assignedTasks  Task[] @relation("TaskAssignee")
  reportedTasks  Task[] @relation("TaskReporter")

  createdEvents   Event[]           @relation("EventCreator")
  eventAttendance EventAttendance[]

  proposals          Proposal[] @relation("ProposalSubmitter")
  memberPerformances MemberPerformance[]

  @@map("profiles")
}

// ────────────────────────────────────────────────────────────
// MODEL 2: Channel
// Kênh chat nội bộ (Public / Private)
// Security: PRIVATE channel chỉ hiện với member trong ChannelMember
// ────────────────────────────────────────────────────────────

model Channel {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  description String?
  type        ChannelType @default(PUBLIC)
  ownerId     String      @map("owner_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  owner       Profile         @relation("ChannelOwner", fields: [ownerId], references: [id])
  members     ChannelMember[]
  messages    Message[]
  pinnedItems PinnedItem[]

  @@map("channels")
}

// Bảng trung gian: Channel <-> Profile (many-to-many)
model ChannelMember {
  id        String   @id @default(uuid()) @db.Uuid
  channelId String   @map("channel_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId]) // Mỗi user chỉ join 1 lần / channel
  @@map("channel_members")
}

// ────────────────────────────────────────────────────────────
// MODEL 3: Message
// Chat với luồng reply (Thread) & tích hợp Task Card
// Security: Chỉ sender mới được edit/delete message của mình
// ────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  channelId  String   @map("channel_id") @db.Uuid
  senderId   String   @map("sender_id") @db.Uuid
  content    String
  // parentId ≠ null → đây là reply trong thread
  parentId   String?  @map("parent_id") @db.Uuid
  // isTaskCard = true → tin nhắn này đã được convert thành Task
  isTaskCard Boolean  @default(false) @map("is_task_card")
  editedAt   DateTime? @map("edited_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  channel    Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender     Profile           @relation("MessageSender", fields: [senderId], references: [id])
  // Self-relation: message cha → replies
  parent     Message?          @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies    Message[]         @relation("MessageThread")
  readStatus MessageReadStatus[]
  pinnedItem PinnedItem[]

  @@index([channelId, createdAt]) // Tối ưu load lịch sử chat
  @@index([parentId])             // Tối ưu load thread
  @@map("messages")
}

// ────────────────────────────────────────────────────────────
// MODEL 4: MessageReadStatus (Read Receipts)
// Theo dõi ai đã đọc tin nhắn nào
// Security: User chỉ có thể ghi trạng thái đọc của chính mình
// ────────────────────────────────────────────────────────────

model MessageReadStatus {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @default(now()) @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId]) // Mỗi user chỉ có 1 trạng thái đọc / tin nhắn
  @@index([userId])
  @@map("message_read_status")
}

// ────────────────────────────────────────────────────────────
// MODEL 5: PinnedItem
// Tài liệu / liên kết / task được ghim trên đầu channel
// Security: Chỉ admin/leader mới được pin (kiểm soát ở app layer)
// ────────────────────────────────────────────────────────────

model PinnedItem {
  id          String   @id @default(uuid()) @db.Uuid
  channelId   String   @map("channel_id") @db.Uuid
  pinnedById  String   @map("pinned_by_id") @db.Uuid
  // Có thể ghim Message hoặc URL tự do
  messageId   String?  @map("message_id") @db.Uuid
  externalUrl String?  @map("external_url")
  label       String?  // Nhãn hiển thị cho URL
  createdAt   DateTime @default(now()) @map("created_at")

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  pinnedBy  Profile  @relation("PinnedBy", fields: [pinnedById], references: [id])
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([channelId])
  @@map("pinned_items")
}

// ────────────────────────────────────────────────────────────
// MODEL 6: Task
// Cây công việc phân cấp (Self-relation)
// Node gốc: Trưởng ban → Leader
// Node con: Leader → Member
// Security: RLS kiểm soát ai được xem/sửa task
// ────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String?
  // Self-relation: task cha → task con (cây phân cấp không giới hạn cấp)
  parentId    String?    @map("parent_id") @db.Uuid
  assigneeId  String?    @map("assignee_id") @db.Uuid
  reporterId  String?    @map("reporter_id") @db.Uuid
  dueDate     DateTime?  @map("due_date") @db.Date
  status      TaskStatus @default(todo)
  // Nếu task được tạo từ tin nhắn (isTaskCard), lưu lại messageId gốc
  sourceMessageId String? @map("source_message_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Self-relation
  parent   Task?  @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Task[] @relation("TaskHierarchy")

  assignee Profile? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter Profile? @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([parentId])
  @@index([assigneeId])
  @@index([status])
  @@map("tasks")
}

// ────────────────────────────────────────────────────────────
// MODEL 7: Event
// Lịch công tác của CLB
// Security: Chỉ admin INSERT/UPDATE/DELETE (enforce bằng RLS SQL bên dưới)
// ────────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  content     String?
  location    String?
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy  Profile           @relation("EventCreator", fields: [createdById], references: [id])
  attendance EventAttendance[]

  @@index([startTime])
  @@map("events")
}

// ────────────────────────────────────────────────────────────
// MODEL 8: EventAttendance
// Điểm danh sự kiện với bắt buộc giải trình nếu vắng mặt
// Security: User chỉ UPDATE bản ghi của chính mình (RLS SQL)
//           excuse bắt buộc khi status = 'no' (CHECK constraint)
// ────────────────────────────────────────────────────────────

model EventAttendance {
  id        String           @id @default(uuid()) @db.Uuid
  eventId   String           @map("event_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  status    AttendanceStatus @default(pending)
  // Bắt buộc khi status = 'no' — enforce bằng CHECK constraint trong SQL
  excuse    String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  event Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId]) // Mỗi user chỉ có 1 phản hồi / sự kiện
  @@index([userId])
  @@map("event_attendance")
}

// ────────────────────────────────────────────────────────────
// MODEL 9: Proposal
// Đề xuất dự án từ các nhóm hoạt động
// Security: Chỉ admin mới được APPROVE/REJECT (app layer + RLS)
// ────────────────────────────────────────────────────────────

model Proposal {
  id            String         @id @default(uuid()) @db.Uuid
  title         String
  description   String
  submittedById String         @map("submitted_by_id") @db.Uuid
  status        ProposalStatus @default(pending)
  // Bắt buộc điền lý do nếu rejected (enforce ở app layer + CHECK constraint)
  rejectReason  String?        @map("reject_reason")
  reviewedAt    DateTime?      @map("reviewed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  submittedBy Profile @relation("ProposalSubmitter", fields: [submittedById], references: [id])

  @@index([status])
  @@index([submittedById])
  @@map("proposals")
}

// ────────────────────────────────────────────────────────────
// MODEL 10: MemberPerformance
// Bảng kiểm soát năng lực thành viên theo tháng
// Security: Chỉ admin/leader ghi; member chỉ đọc + tự nộp explanation
// ────────────────────────────────────────────────────────────

model MemberPerformance {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  month             Int      // 1-12
  year              Int
  tasksCompleted    Int      @default(0) @map("tasks_completed")
  eventsAttended    Int      @default(0) @map("events_attended")
  // Điểm chất lượng đầu vào (0.00 - 10.00)
  qualityScore      Decimal  @default(0) @map("quality_score") @db.Decimal(4, 2)
  // % tiến độ tổng hợp (0.00 - 100.00)
  progressPercent   Decimal  @default(0) @map("progress_percent") @db.Decimal(5, 2)
  // Giải trình cuối tháng nếu không đạt chỉ tiêu
  explanation       String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year]) // Mỗi tháng chỉ có 1 bản ghi / thành viên
  @@index([userId])
  @@index([year, month])
  @@map("member_performance")
}
